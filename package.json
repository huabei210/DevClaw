{
  "name": "feishu-thread-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Feishu Thread Bridge v1: self-hosted bridge for directing Feishu messages into local Codex threads.",
  "license": "Apache-2.0",
  "scripts": {
    "postinstall": "node scripts/install-official-codex.js",
    "build": "tsc -p tsconfig.json",
    "dev:gateway": "tsx watch src/gateway/index.ts",
    "dev:agent": "tsx watch src/agent/index.ts",
    "install:codex": "node scripts/install-official-codex.js",
    "start:gateway": "node dist/gateway/index.js",
    "start:agent": "node dist/agent/index.js",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "express": "^5.1.0",
    "mime-types": "^3.0.1",
    "multer": "^2.0.2",
    "ws": "^8.18.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/mime-types": "^2.1.4",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.5.2",
    "@types/ws": "^8.18.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
